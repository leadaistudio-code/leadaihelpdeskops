generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  IT_AGENT
  EMPLOYEE
}

// A tenant. Every data model carries a `domain` string that references a
// Domain.slug; all queries are scoped to the caller's active domain.
model Domain {
  slug      String   @id
  name      String
  createdAt DateTime @default(now())
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  password         String?
  role             Role              @default(EMPLOYEE)
  department       String?
  incidentsRaised  Incident[]        @relation("Caller")
  incidentsAssigned Incident[]       @relation("Assignee")
  articles         KnowledgeArticle[]
  assets           Asset[]           @relation("AssignedAssets")
  incidentNotes    IncidentNote[]
  problemsAssigned Problem[]         @relation("ProblemAssignee")
  problemNotes     ProblemNote[]
  catalogRequests  CatalogRequest[]
  notifications    Notification[]
  uploads          Attachment[]
  groups           AssignmentGroup[] @relation("GroupMembers")
  devices          Device[]          @relation("DeviceOwner")
  emailNotifications Boolean         @default(true)
  moduleAccess     String[]          @default(["SELF_SERVICE"])
  jobTitle         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  domain           String            @default("global")
}

enum NotificationType {
  ASSIGNMENT
  APPROVAL
  REJECTION
  RESOLUTION
  COMMENT
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  type      NotificationType @default(GENERAL)
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

enum IncidentStatus {
  NEW
  IN_PROGRESS
  ON_HOLD
  PENDING_APPROVAL
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketType {
  INCIDENT
  REQUEST
}

enum SlaSchedule {
  ALWAYS   // 24x7 — calendar hours
  BUSINESS // Mon–Fri 09:00–17:00 — business hours
}

enum SlaStage {
  IN_PROGRESS
  PAUSED
  MET
  BREACHED
}

model SlaDefinition {
  id            String      @id @default(cuid())
  name          String
  type          TicketType
  priority      Priority
  durationHours Int
  schedule      SlaSchedule @default(ALWAYS)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  domain        String      @default("global")
}

// A live SLA clock attached to an incident: computes an effective due time,
// pauses while ON_HOLD, and is marked MET or BREACHED when the ticket stops.
model SlaInstance {
  id              String      @id @default(cuid())
  incidentId      String
  incident        Incident    @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  slaDefinitionId String?
  name            String
  targetHours     Int
  schedule        SlaSchedule @default(ALWAYS)
  startAt         DateTime    @default(now())
  dueAt           DateTime
  stage           SlaStage    @default(IN_PROGRESS)
  pausedAt        DateTime?
  pausedMs        Int         @default(0) // accumulated paused business-ms
  breachedAt      DateTime?
  stoppedAt       DateTime?
  escalatedAt     DateTime?
  domain          String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([domain, stage])
  @@index([incidentId])
}

model Incident {
  id          String         @id @default(cuid())
  // Unique per tenant, not globally — see NumberCounter.
  number      String // e.g., INC0010001
  title       String
  description String
  status      IncidentStatus @default(NEW)
  priority    Priority       @default(LOW)
  type        TicketType     @default(INCIDENT)
  
  callerId    String
  caller      User           @relation("Caller", fields: [callerId], references: [id])
  
  assigneeId  String?
  assignee    User?          @relation("Assignee", fields: [assigneeId], references: [id])

  assignmentGroupId String?
  assignmentGroup   AssignmentGroup? @relation(fields: [assignmentGroupId], references: [id])

  notes       IncidentNote[]
  attachments Attachment[]
  slaInstances SlaInstance[]

  // A recurring incident can be linked to a Problem record for root-cause work.
  problemId   String?
  problem     Problem?       @relation(fields: [problemId], references: [id])

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  domain      String         @default("global")

  @@unique([domain, number])
  @@index([domain, assignmentGroupId])
  @@index([domain, problemId])
}

// A queue/team that incidents route to (Network Support, Hardware, Access…).
model AssignmentGroup {
  id        String     @id @default(cuid())
  name      String
  domain    String
  members   User[]     @relation("GroupMembers")
  incidents Incident[]
  createdAt DateTime   @default(now())

  @@index([domain])
}

// Per-tenant DEX settings (server-side self-heal toggle, etc.).
model TenantSettings {
  domain    String   @id
  autoHeal  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  mimeType     String
  size         Int
  data         Bytes

  // An attachment belongs to either an incident or a knowledge article.
  incidentId   String?
  incident     Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  articleId    String?
  article      KnowledgeArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  createdAt    DateTime @default(now())

  @@index([incidentId])
  @@index([articleId])
}

enum NoteType {
  COMMENT
  WORK_NOTE
  SYSTEM
}

model IncidentNote {
  id         String   @id @default(cuid())
  body       String
  type       NoteType @default(COMMENT)

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])

  createdAt  DateTime @default(now())
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  content     String
  isPublished Boolean  @default(false)

  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  attachments Attachment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  domain      String   @default("global")
}

enum AssetStatus {
  IN_USE
  IN_STOCK
  RETIRED
  MISSING
}

model Asset {
  id           String      @id @default(cuid())
  assetTag     String      @unique
  name         String
  category     String      // e.g., "Hardware", "Software"
  status       AssetStatus @default(IN_STOCK)
  
  assigneeId   String?
  assignee     User?       @relation("AssignedAssets", fields: [assigneeId], references: [id])
  
  purchaseDate DateTime?
  notes        String?
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  domain       String      @default("global")
}

model CatalogItem {
  id          String           @id @default(cuid())
  name        String
  description String
  category    String           // e.g., "Hardware", "Software", "Access"
  icon        String?          // lucide icon key
  imageUrl    String?          // product image
  specs       Json?            // ["16GB RAM", "512GB SSD"]
  formSchema  Json?            // custom request form schema
  price       Float?           // optional showback cost
  isActive    Boolean          @default(true)
  requests    CatalogRequest[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  domain      String           @default("global")
}

// A real endpoint (laptop/PC) running the DEX agent, scoped to a tenant.
model Device {
  id          String   @id @default(cuid())
  deviceKey   String   @unique // bearer secret the agent uses to post metrics
  hostname    String
  os          String?
  user        String?  // logged-in OS user reported by the agent (free-text)
  domain      String   // tenant
  persona     String?  // e.g., "Developer", "Sales"

  // Authoritative owner: the app User this device belongs to. Distinct from the
  // free-text `user` OS-name above — this is a real link, set by enrollment
  // best-effort match or explicit assignment, and used to answer "my device".
  ownerId     String?
  owner       User?    @relation("DeviceOwner", fields: [ownerId], references: [id])

  // Latest snapshot (denormalized for a fast dashboard).
  cpuPct      Float?
  memUsedMb   Int?
  memTotalMb  Int?
  diskPct     Float?
  uptimeSec   Int?
  latencyMs   Int?
  batteryPct  Int?
  cpuCores    Int?
  lastSeenAt  DateTime?
  extendedInfo Json?

  // Proactive monitoring: when we last auto-raised an alert for this device.
  lastAlertAt DateTime?

  enrolledAt  DateTime @default(now())
  metrics             DeviceMetric[]
  commands            RemoteCommand[]
  appCrashes          AppCrashEvent[]
  hardwarePredictions HardwareFailurePrediction[]
  installations       SoftwareInstallation[]
  softwareUsage       SoftwareUsage[]
  microSurveys        MicroSurveyResponse[]
  bootProfiles        BootProfile[]
  securityPostures    SecurityPosture[]

  @@index([domain])
  @@index([domain, ownerId])
}

model DeviceMetric {
  id         String   @id @default(cuid())
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  cpuPct     Float
  memUsedMb  Int
  memTotalMb Int
  diskPct    Float?
  uptimeSec  Int?
  latencyMs  Int?
  batteryPct    Int?
  wifiSsid      String?
  wifiSignalDbm Int?
  packetLossPct Float?
  extendedInfo  Json?
  createdAt     DateTime @default(now())

  @@index([deviceId, createdAt])
}

enum CommandStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

// A remediation action queued for an agent to pull and execute on the endpoint.
model RemoteCommand {
  id          String        @id @default(cuid())
  deviceId    String
  device      Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  action      String        // FLUSH_DNS | CLEAR_TEMP | RESTART_SPOOLER | REBOOT
  status      CommandStatus @default(QUEUED)
  result      String?
  domain      String
  createdAt   DateTime      @default(now())
  completedAt DateTime?

  @@index([deviceId, status])
}

// One enrollment token per tenant; the agent presents it once to enroll.
model EnrollmentToken {
  domain    String   @id
  token     String   @unique
  createdAt DateTime @default(now())
}

model Flow {
  id          String   @id @default(cuid())
  name        String
  // Serialized node list: [{ id, type, name, desc }]
  definition  Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  domain      String   @default("global")
}

enum RequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  FULFILLED
}

model CatalogRequest {
  id          String        @id @default(cuid())
  itemId      String
  item        CatalogItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  requesterId String
  requester   User          @relation(fields: [requesterId], references: [id])

  status      RequestStatus @default(REQUESTED)
  notes       String?

  // Links to the work-queue incident opened for this request, so approvals
  // stay in sync between the request record and the ticket.
  incidentId  String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  domain      String        @default("global")
}

// Marketing lead captured by a gated content download (e.g. the CIO's Guide).
// Not tenant-scoped — these are inbound prospects, not signed-in users.
model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String
  jobTitle  String
  // Which gated asset they requested, e.g. "cio-autonomous-it".
  guide     String
  // Lightweight attribution for where the form was submitted from.
  source    String?
  // Set true once the download has been served at least once.
  downloaded Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([guide, createdAt])
  @@index([email])
}

enum ProblemStatus {
  NEW
  INVESTIGATING
  ROOT_CAUSE_IDENTIFIED
  KNOWN_ERROR
  RESOLVED
  CLOSED
}

// ITIL Problem record: root-cause analysis behind one or more incidents.
model Problem {
  id          String        @id @default(cuid())
  // Unique per tenant, not globally — see NumberCounter.
  number      String // e.g., PRB0000001
  title       String
  description String
  status      ProblemStatus @default(NEW)
  priority    Priority      @default(MEDIUM)

  rootCause   String? // findings of the RCA
  workaround  String? // interim workaround (a Known Error once published)
  knownError  Boolean       @default(false)

  assigneeId  String?
  assignee    User?         @relation("ProblemAssignee", fields: [assigneeId], references: [id])

  incidents   Incident[] // incidents linked to this problem
  notes       ProblemNote[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  resolvedAt  DateTime?
  domain      String        @default("global")

  @@unique([domain, number])
  @@index([domain, status])
}

// Per-tenant ticket numbering.
//
// Numbers used to be derived from a live count() of the table, which was both a
// cross-tenant leak (the count spanned every customer) and a race (two
// concurrent creates read the same count and produced the same number). This
// row is the allocator instead: an atomic INSERT ... ON CONFLICT DO UPDATE
// hands out the next value under a row lock, so concurrent creates can't
// collide, and each tenant counts from its own base.
//
// `last` is the most recently allocated number for the series.
model NumberCounter {
  domain String
  series String // "INC" | "REQ" | "PRB"
  last   Int

  @@id([domain, series])
}

model ProblemNote {
  id        String   @id @default(cuid())
  body      String
  type      NoteType @default(COMMENT)

  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

// Immutable audit trail — every significant write across the platform records
// who did what, to which entity, and when. Append-only; never edited.
model AuditLog {
  id          String   @id @default(cuid())
  domain      String
  // Who (denormalized snapshot; actor may be "System" for automated events)
  actorId     String?
  actorName   String?
  actorEmail  String?
  // What
  action      String   // CREATE | UPDATE | STATE_CHANGE | ASSIGN | APPROVE | REJECT | LINK | UNLINK | REMEDIATION | SLA_BREACH | ROLE_CHANGE
  entityType  String   // Incident | Problem | CatalogRequest | Device | User | SlaInstance
  entityId    String?
  entityLabel String?  // e.g. "INC0001234", "PRB0000007"
  summary     String
  // Optional structured diff
  field       String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  @@index([domain, createdAt])
  @@index([domain, entityType, entityId])
  @@index([domain, actorId])
}

model AppCrashEvent {
  id         String   @id @default(cuid())
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  appName    String   // e.g., "zoom.exe"
  appVersion String?  // e.g., "5.14.2"
  eventType  String   // "CRASH" or "HANG"
  domain     String   // Tenant isolation
  createdAt  DateTime @default(now())

  @@index([domain, appName])
  @@index([deviceId, createdAt])
}

model HardwareFailurePrediction {
  id            String   @id @default(cuid())
  deviceId      String
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  component     String   // "BATTERY", "DISK", "CPU_THERMAL"
  probability   Float    // 0-1
  predictedDate DateTime?
  status        String   // "WARNING", "CRITICAL", "RESOLVED"
  domain        String
  createdAt     DateTime @default(now())

  @@index([deviceId, component])
}

model SoftwareInstallation {
  id           String   @id @default(cuid())
  deviceId     String
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  softwareName String
  version      String?
  domain       String
  installedAt  DateTime @default(now())

  @@unique([deviceId, softwareName])
  @@index([domain, softwareName])
}

model SoftwareUsage {
  id                String   @id @default(cuid())
  deviceId          String
  device            Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  softwareName      String
  foregroundMinutes Int      @default(0)
  lastUsedAt        DateTime?
  domain            String
  updatedAt         DateTime @updatedAt

  @@unique([deviceId, softwareName])
  @@index([domain, softwareName])
}

model RemediationCampaign {
  id             String   @id @default(cuid())
  name           String
  runbook        String
  targetCriteria String   // e.g., JSON representation of filter criteria
  status         String   // "DRAFT", "RUNNING", "COMPLETED"
  totalTargeted  Int      @default(0)
  successCount   Int      @default(0)
  domain         String
  createdAt      DateTime @default(now())

  @@index([domain, status])
}

model MicroSurveyResponse {
  id           String   @id @default(cuid())
  deviceId     String
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  triggerEvent String   // e.g., "APP_CRASH_zoom.exe"
  question     String
  rating       Int      // 1-5
  comment      String?
  domain       String
  createdAt    DateTime @default(now())

  @@index([deviceId, triggerEvent])
  @@index([domain, triggerEvent])
}

model BootProfile {
  id             String   @id @default(cuid())
  deviceId       String
  device         Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  totalBootSec   Int
  biosSec        Int?
  osBootSec      Int?
  profileLoadSec Int?
  gpoSec         Int?
  domain         String
  createdAt      DateTime @default(now())

  @@index([deviceId, createdAt])
}

model SecurityPosture {
  id              String   @id @default(cuid())
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  bitlockerActive Boolean  @default(false)
  avUpdated       Boolean  @default(false)
  firewallActive  Boolean  @default(false)
  domain          String
  createdAt       DateTime @default(now())

  @@index([deviceId, createdAt])
}

model SmartContract {
  id              String   @id @default(cuid())
  name            String
  metric          String   // "CPU", "RAM", "DISK"
  operator        String   // ">", "<"
  threshold       Float
  action          String   // "CLEAR_TEMP", "RESTART_SPOOLER", "REBOOT", "FLUSH_DNS"
  isActive        Boolean  @default(true)
  triggersCount   Int      @default(0)
  domain          String
  createdAt       DateTime @default(now())

  @@index([domain, isActive])
}
