{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "prod-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start", "--", "-p", "3002"],
      "port": 3002
    },
    {
      "name": "remotion-studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "video:preview", "--", "--port=3001"],
      "port": 3001
    },
    {
      "name": "prisma-studio",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["prisma", "studio", "--port", "5555", "--browser", "none"],
      "port": 5555
    }
  ]
}
